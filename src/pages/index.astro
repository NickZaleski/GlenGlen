---
import Layout from "../layouts/Layout.astro";

// =====================================================================
//  TRACKS  ->  ADD YOUR 5 AUDIO FILES HERE
// ---------------------------------------------------------------------
//  1. Drop the audio files into:  public/audio/
//  2. Reference them below in `src` as "/audio/<filename>".
//     (Anything in public/ is served from the site root, so a file at
//      public/audio/little-peek.mp3 is reachable at "/audio/little-peek.mp3")
// =====================================================================
const tracks = [
  { title: "Little Peek", duration: "02:52", src: "/audio/little-peek.mp3" },
  { title: "At the Gates of Rimal Kubra", duration: "03:05", src: "/audio/at-the-gates-of-rimal-kubra.mp3" },
  { title: "The Ascension of Rimal Kubra", duration: "01:26", src: "/audio/the-ascension-of-rimal-kubra.mp3" },
  { title: "Icarus' Curse", duration: "02:56", src: "/audio/icarus-curse.mp3" },
  { title: "Giants from the East and Elders", duration: "03:21", src: "/audio/giants-from-the-east-and-elders.mp3" },
];

const SITE_URL = "https://glen-glen.vercel.app/";
const GENRE = "Psychedelic Rock";
const description = `GlenGlen — ${GENRE}. Stream the latest tracks including ${tracks
  .slice(0, 3)
  .map((t) => t.title)
  .join(", ")} and more.`;

// Convert "mm:ss" to ISO 8601 duration (e.g. "02:52" -> "PT2M52S").
const toIso = (mmss: string) => {
  const [m, s] = mmss.split(":").map(Number);
  return `PT${m}M${s}S`;
};

const abs = (path: string) => new URL(path, SITE_URL).href;

// schema.org: the band, with its catalogue of recordings.
const musicGroupSchema = {
  "@context": "https://schema.org",
  "@type": "MusicGroup",
  name: "GlenGlen",
  genre: GENRE,
  url: SITE_URL,
  image: abs("/og-image.png"),
  track: tracks.map((t) => ({
    "@type": "MusicRecording",
    name: t.title,
    duration: toIso(t.duration),
    byArtist: { "@type": "MusicGroup", name: "GlenGlen" },
    associatedMedia: {
      "@type": "AudioObject",
      contentUrl: abs(t.src),
      encodingFormat: "audio/mpeg",
    },
  })),
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "GlenGlen",
  url: SITE_URL,
};
---

<Layout
  title="GlenGlen — Psychedelic Rock"
  description={description}
  schema={[musicGroupSchema, websiteSchema]}
>
  <!-- The audio-reactive liquid background lives in Layout.astro (#liquid-canvas)
       and covers the viewport behind everything. No static hero image. -->

  <!-- Main Content Canvas -->
  <main
    class="relative z-10 flex-grow flex flex-col items-center justify-center px-margin-mobile md:px-margin-desktop w-full py-10 md:py-14 gap-9 md:gap-16"
  >
    <!-- Band Identity: chromatic-aberration wordmark (see .wordmark in Layout) -->
    <div class="text-center select-none">
      <div class="flex justify-center">
        <h1
          class="wordmark font-display-lg tracking-tighter text-[clamp(3.75rem,14vw,12rem)]"
          aria-label="GlenGlen"
        >
          <span class="layer ghost magenta" aria-hidden="true">GlenGlen</span>
          <span class="layer ghost cyan" aria-hidden="true">GlenGlen</span>
          <span class="layer base">GlenGlen</span>
        </h1>
      </div>
      <div class="genre-tag mt-6 md:mt-7 inline-flex items-center gap-2.5 rounded-full px-6 py-2 md:px-8 md:py-2.5">
        <span class="w-1.5 h-1.5 rounded-full bg-primary shadow-[0_0_8px_rgba(86,251,160,0.9)] animate-pulse"></span>
        <span class="font-label-sm text-label-sm md:text-sm text-primary/90 tracking-[0.3em] uppercase">Psychedelic Rock</span>
      </div>
    </div>

    <!-- Music Player Container -->
    <div class="w-full max-w-2xl lg:max-w-3xl glass-panel bg-[rgba(5,16,14,0.45)] rounded-2xl overflow-hidden flex flex-col backdrop-blur-2xl shadow-[0_20px_80px_-20px_rgba(0,0,0,0.7)] ring-1 ring-primary/10">
      <!-- Tracklist -->
      <div class="p-2 sm:p-unit md:p-gutter">
        <ul class="flex flex-col gap-1 sm:gap-2" id="tracklist">
          {
            tracks.map((track, i) => (
              <li
                class:list={[
                  "track-item flex items-center justify-between p-3 md:p-4 rounded-lg transition-colors cursor-pointer group min-h-[56px]",
                  i === 0 ? "bg-white/5 hover:bg-white/10" : "hover:bg-white/5",
                ]}
                data-index={i}
                data-src={track.src}
                data-title={track.title}
              >
                <div class="flex items-center gap-4 md:gap-5 min-w-0">
                  <span
                    class:list={[
                      "track-indicator relative flex items-center justify-center w-6 h-6 md:w-7 md:h-7 shrink-0 transition-colors group-hover:text-primary",
                      i === 0 ? "text-primary/50" : "text-on-surface-variant/50",
                    ]}
                  >
                    {/* Play icon: shown by default; hidden while this track is playing */}
                    <span class="track-icon-play material-symbols-outlined absolute inset-0 flex items-center justify-center">
                      play_arrow
                    </span>
                    {/* Pause icon: shown on hover while this track is playing */}
                    <span class="track-icon-pause material-symbols-outlined absolute inset-0 hidden items-center justify-center text-primary">
                      pause
                    </span>
                    {/* Animated equalizer: shown while this track is playing (and not hovered) */}
                    <span class="track-eq hidden gap-[2px] items-end h-3 text-primary" aria-hidden="true">
                      <span class="eq-bar"></span>
                      <span class="eq-bar"></span>
                      <span class="eq-bar"></span>
                    </span>
                  </span>
                  <div class="min-w-0">
                    <h3
                      class:list={[
                        "track-title font-track-title text-[16px] sm:text-[17px] md:text-[19px] leading-snug tracking-normal truncate transition-colors group-hover:text-on-surface",
                        i === 0 ? "text-on-surface font-semibold" : "text-on-surface/80 font-medium",
                      ]}
                    >
                      {track.title}
                    </h3>
                    <p
                      class:list={[
                        "font-label-sm text-[11px] md:text-[12px] tracking-wider mt-0.5 tabular-nums",
                        i === 0 ? "text-on-surface-variant" : "text-on-surface-variant/70",
                      ]}
                    >
                      {track.duration}
                    </p>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Current Track Controls (Integrated into container) -->
      <div class="relative bg-[rgba(5,16,14,0.55)] p-4 sm:p-gutter md:p-8 border-t border-primary/15 flex flex-col gap-4 md:gap-5">
        <!-- Progress Bar -->
        <div class="w-full flex items-center gap-3">
          <span class="font-label-sm text-label-sm text-on-surface-variant tabular-nums w-10 text-right" id="current-time">
            00:00
          </span>
          <div
            class="progress-bar group/progress flex-grow relative flex items-center h-4 cursor-pointer select-none touch-none"
            id="progress-track"
            role="slider"
            tabindex="0"
            aria-label="Seek"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
          >
            <!-- Rail -->
            <div class="progress-rail relative w-full h-1 bg-surface-variant rounded-full overflow-visible transition-[height] duration-150 ease-out">
              <!-- Hover preview (where you'd seek to) -->
              <div
                class="absolute top-0 left-0 h-full w-0 bg-on-surface/10 rounded-full opacity-0 group-hover/progress:opacity-100 transition-opacity pointer-events-none"
                id="progress-hover"
              >
              </div>
              <!-- Played portion -->
              <div
                class="absolute top-0 left-0 h-full w-0 rounded-full bg-gradient-to-r from-primary to-cyan-300 shadow-[0_0_12px_rgba(86,251,160,0.7)]"
                style="--tw-gradient-to:#35e0ff;"
                id="progress-fill"
              >
                <!-- Draggable thumb -->
                <span
                  class="progress-thumb absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 w-3 h-3 rounded-full bg-primary shadow-[0_0_10px_rgba(86,251,160,0.95)] scale-0 group-hover/progress:scale-100 transition-transform duration-150 ease-out"
                  id="progress-thumb"
                >
                </span>
              </div>
            </div>
          </div>
          <span class="font-label-sm text-label-sm text-on-surface-variant tabular-nums w-10" id="total-time">00:00</span>
        </div>

        <!-- Controls.
             Mobile: now-playing row on top, transport centered below.
             sm+:    three balanced columns (now-playing | transport | volume)
                     so the transport sits optically centered. -->
        <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-4">
          <!-- Now playing (artwork + title). Shows on every viewport. -->
          <div class="flex items-center gap-3 md:gap-4 min-w-0 sm:flex-1 sm:basis-0">
            <div class="now-playing-art w-12 h-12 md:w-14 md:h-14 rounded-md bg-surface-variant/50 flex items-center justify-center overflow-hidden relative shrink-0">
              <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-secondary/20"></div>
              <!-- Static icon when paused -->
              <span class="now-playing-icon material-symbols-outlined text-primary/80 absolute md:text-[28px]">graphic_eq</span>
              <!-- Animated equalizer while playing -->
              <span class="now-playing-eq track-eq gap-[3px] items-end h-4 md:h-5 text-primary" aria-hidden="true">
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
                <span class="eq-bar"></span>
              </span>
            </div>
            <div class="min-w-0">
              <h4 class="font-track-title text-[15px] md:text-[17px] text-on-surface font-semibold leading-tight truncate" id="now-playing-title">
                {tracks[0].title}
              </h4>
              <p class="font-label-sm text-on-surface-variant/70 text-[11px] md:text-xs">GlenGlen</p>
            </div>
          </div>
          <!-- Transport -->
          <div class="flex items-center gap-8 sm:gap-6 md:gap-7 shrink-0 justify-center">
            <button
              class="w-11 h-11 flex items-center justify-center rounded-full text-on-surface-variant hover:text-primary active:scale-95 transition-all"
              id="prev-btn"
              aria-label="Previous track"
            >
              <span class="material-symbols-outlined md:text-[28px]">skip_previous</span>
            </button>
            <button
              class="w-14 h-14 md:w-16 md:h-16 rounded-full bg-primary text-on-primary flex items-center justify-center neon-glow hover:scale-105 active:scale-95 transition-all"
              id="play-btn"
              aria-label="Play or pause"
            >
              <span class="material-symbols-outlined md:text-[32px]" id="play-icon" style="font-variation-settings: 'FILL' 1;">
                play_arrow
              </span>
            </button>
            <button
              class="w-11 h-11 flex items-center justify-center rounded-full text-on-surface-variant hover:text-primary active:scale-95 transition-all"
              id="next-btn"
              aria-label="Next track"
            >
              <span class="material-symbols-outlined md:text-[28px]">skip_next</span>
            </button>
          </div>
          <!-- Volume (pointer devices only; touch users use OS volume).
               Balances the now-playing column (flex-1 basis-0) so the transport
               stays optically centered, while the slider hugs the right edge. -->
          <div class="hidden sm:flex items-center gap-2.5 sm:flex-1 sm:basis-0 justify-end">
            <span class="material-symbols-outlined text-on-surface-variant text-[20px] leading-none">volume_up</span>
            <div class="group/vol w-20 md:w-28 h-4 flex items-center cursor-pointer" id="volume-track">
              <div class="relative w-full h-1.5 bg-surface-variant rounded-full overflow-hidden">
                <div class="h-full w-2/3 bg-primary/70 group-hover/vol:bg-primary rounded-full transition-colors" id="volume-fill"></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

</Layout>

<script>
  import { initLiquid } from "../scripts/liquid";

  // Audio-reactive liquid light show. Rendered behind the UI; fed by the two
  // audio decks so the visuals pulse to whatever is playing. `crossOrigin` must
  // be set before any src is assigned so MediaElementSource can read samples.
  const liquid = initLiquid("liquid-canvas");

  const items = Array.from(document.querySelectorAll<HTMLLIElement>(".track-item"));
  const playBtn = document.getElementById("play-btn");
  const playIcon = document.getElementById("play-icon");
  const prevBtn = document.getElementById("prev-btn");
  const nextBtn = document.getElementById("next-btn");
  const progressTrack = document.getElementById("progress-track");
  const progressFill = document.getElementById("progress-fill");
  const currentTimeEl = document.getElementById("current-time");
  const totalTimeEl = document.getElementById("total-time");
  const nowPlayingTitle = document.getElementById("now-playing-title");
  const volumeTrack = document.getElementById("volume-track");
  const volumeFill = document.getElementById("volume-fill");

  // ===== Crossfade configuration =====
  // Length of the overlap between a track ending and the next starting.
  // No silent gap occurs: the next track begins while the current is still
  // fading out. Tweak this value (in seconds) to taste.
  const CROSSFADE_SECONDS = 0.6;

  // Two "decks" let us overlap two tracks for a true gapless crossfade.
  // A single <audio> element can't overlap with itself.
  const decks = [new Audio(), new Audio()];
  decks.forEach((d) => {
    d.preload = "auto";
    // Route each deck through the shared analyser so the liquid background can
    // read its frequency data. (Same-origin audio, so no CORS concerns.)
    liquid?.connect(d);
  });
  let activeDeck = 0; // index into `decks` that is the foreground track
  let masterVolume = decks[0].volume; // user-set volume (0..1), independent of fade
  let crossfading = false;
  let scrubbing = false; // true while the user is dragging the progress bar

  const audio = () => decks[activeDeck];
  const other = () => decks[activeDeck === 0 ? 1 : 0];

  let current = 0;

  const fmt = (s: number) => {
    if (!isFinite(s)) return "00:00";
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return `${String(m).padStart(2, "0")}:${String(sec).padStart(2, "0")}`;
  };

  function highlight(index: number) {
    items.forEach((item, i) => {
      const icon = item.querySelector(".track-icon");
      const title = item.querySelector(".track-title");
      if (i === index) {
        item.classList.add("bg-white/5");
        icon?.classList.add("text-primary/50");
        icon?.classList.remove("text-on-surface-variant/50");
        title?.classList.add("text-on-surface", "font-semibold");
        title?.classList.remove("text-on-surface/80", "font-medium");
      } else {
        item.classList.remove("bg-white/5");
        icon?.classList.remove("text-primary/50");
        icon?.classList.add("text-on-surface-variant/50");
        title?.classList.remove("text-on-surface", "font-semibold");
        title?.classList.add("text-on-surface/80", "font-medium");
      }
    });
  }

  function setPlayingState(playing: boolean) {
    items.forEach((item, i) => {
      item.classList.toggle("is-playing", playing && i === current);
    });
    // Drives the animated equalizer in the now-playing artwork tile.
    document.body.classList.toggle("is-playing", playing);
  }

  function updateNowPlaying(index: number) {
    const item = items[index];
    if (!item) return;
    if (nowPlayingTitle) nowPlayingTitle.textContent = item.dataset.title ?? "";
    highlight(index);
  }

  // Load a track onto the active deck and (optionally) play it.
  // Used for explicit selection / prev / next, NOT for the auto crossfade.
  function load(index: number, autoplay = false) {
    const item = items[index];
    if (!item) return;
    cancelCrossfade();
    current = index;
    const deck = audio();
    deck.volume = masterVolume;
    deck.src = item.dataset.src ?? "";
    updateNowPlaying(index);
    setPlayingState(false);
    if (autoplay) deck.play().catch(() => {});
  }

  function togglePlay() {
    // AudioContext must be resumed from within a user gesture (autoplay policy).
    liquid?.resume();
    const deck = audio();
    if (!deck.src) {
      load(current, true);
      return;
    }
    if (deck.paused) deck.play().catch(() => {});
    else deck.pause();
  }

  // ===== Crossfade engine =====
  //
  // Background-tab correctness: when a tab is open but NOT focused/visible,
  // browsers throttle requestAnimationFrame to a near-stop and slow `timeupdate`
  // events down to ~once per second or worse. Relying on those alone makes track
  // switching lag (the next track starts late) or hang mid-fade. To stay gapless
  // regardless of visibility we:
  //   1. SCHEDULE the crossfade with a setTimeout armed from track metadata, so
  //      it fires on time even when timeupdate is throttled.
  //   2. RAMP volume off a timer-driven clock (setInterval) instead of rAF, so
  //      the fade completes even when rAF is frozen. Timers keep firing in
  //      background tabs (clamped, but they fire); rAF does not.
  //   3. Keep `ended` as a final safety net.
  let crossfadeTimer = 0; // setInterval handle driving the volume ramp
  let crossfadeStart = 0; // performance.now() when the current fade began
  let scheduledFadeTimeout = 0; // setTimeout handle that triggers startCrossfade

  function clearScheduledFade() {
    if (scheduledFadeTimeout) clearTimeout(scheduledFadeTimeout);
    scheduledFadeTimeout = 0;
  }

  // Arm a timer to begin the crossfade exactly CROSSFADE_SECONDS before the end
  // of the active deck. Re-armed on metadata load, seek, and play. This is the
  // primary trigger; `timeupdate` is only a backup for when the timer drifts.
  function scheduleFade() {
    clearScheduledFade();
    const deck = audio();
    if (!deck.duration || !isFinite(deck.duration) || deck.paused) return;
    const remaining = deck.duration - deck.currentTime - CROSSFADE_SECONDS;
    if (remaining <= 0) {
      if (!crossfading) startCrossfade();
      return;
    }
    scheduledFadeTimeout = window.setTimeout(() => {
      if (!crossfading && !audio().paused) startCrossfade();
    }, remaining * 1000);
  }

  function cancelCrossfade() {
    if (crossfadeTimer) clearInterval(crossfadeTimer);
    crossfadeTimer = 0;
    clearScheduledFade();
    crossfading = false;
    // Make sure the background deck is stopped and silenced.
    const bg = other();
    bg.pause();
    bg.currentTime = 0;
    bg.volume = masterVolume;
  }

  // Begin overlapping the next track on the other deck and ramp volumes.
  function startCrossfade() {
    if (crossfading) return;
    clearScheduledFade();
    const nextIndex = (current + 1) % items.length;
    const item = items[nextIndex];
    if (!item) return;

    crossfading = true;
    const fromDeck = audio();
    const toDeck = other();

    toDeck.src = item.dataset.src ?? "";
    toDeck.currentTime = 0;
    toDeck.volume = 0;

    // Once the incoming track can play, the foreground switches to it so the
    // UI (progress, title, indicator) tracks the track you actually hear.
    current = nextIndex;
    activeDeck = activeDeck === 0 ? 1 : 0; // toDeck becomes active
    updateNowPlaying(current);
    setPlayingState(true);

    toDeck.play().catch(() => {});

    crossfadeStart = performance.now();
    const durationMs = CROSSFADE_SECONDS * 1000;

    const apply = () => {
      const t = Math.min(1, (performance.now() - crossfadeStart) / durationMs);
      // Equal-power crossfade keeps perceived loudness constant (no dip).
      const inGain = Math.sin((t * Math.PI) / 2);
      const outGain = Math.cos((t * Math.PI) / 2);
      toDeck.volume = masterVolume * inGain;
      fromDeck.volume = masterVolume * outGain;
      if (t >= 1) {
        if (crossfadeTimer) clearInterval(crossfadeTimer);
        crossfadeTimer = 0;
        fromDeck.pause();
        fromDeck.currentTime = 0;
        fromDeck.volume = masterVolume;
        toDeck.volume = masterVolume;
        crossfading = false;
        // Arm the next track's fade as soon as this one settles.
        scheduleFade();
      }
    };

    // A ~30ms interval is silky when visible and still advances (clamped to
    // ~1s) when hidden — either way the fade reaches completion. rAF would
    // freeze entirely in a background tab, so we deliberately avoid it here.
    if (crossfadeTimer) clearInterval(crossfadeTimer);
    crossfadeTimer = window.setInterval(apply, 30);
    apply();
  }

  playBtn?.addEventListener("click", togglePlay);
  prevBtn?.addEventListener("click", () => load((current - 1 + items.length) % items.length, !audio().paused));
  nextBtn?.addEventListener("click", () => load((current + 1) % items.length, !audio().paused));

  items.forEach((item, i) => {
    item.addEventListener("click", () => {
      liquid?.resume(); // user gesture — safe to start the AudioContext
      // Clicking the track that's already loaded toggles play/pause
      // instead of restarting it; clicking a different track loads + plays it.
      if (i === current && audio().src && !crossfading) {
        togglePlay();
      } else {
        load(i, true);
      }
    });
  });

  // Wire shared playback events for BOTH decks; handlers act only when the
  // event comes from whichever deck is currently active.
  decks.forEach((deck) => {
    deck.addEventListener("play", () => {
      if (deck !== audio()) return;
      if (playIcon) playIcon.textContent = "pause";
      setPlayingState(true);
      // (Re)arm the timer-based fade trigger now that we're actually playing.
      if (!crossfading) scheduleFade();
    });
    deck.addEventListener("pause", () => {
      if (deck !== audio() || crossfading) return;
      if (playIcon) playIcon.textContent = "play_arrow";
      setPlayingState(false);
      // No point holding a fade timer for a paused track; it re-arms on play.
      clearScheduledFade();
    });
    deck.addEventListener("loadedmetadata", () => {
      if (deck !== audio()) return;
      if (totalTimeEl) totalTimeEl.textContent = fmt(deck.duration);
      scheduleFade();
    });
    deck.addEventListener("timeupdate", () => {
      if (deck !== audio()) return;
      if (currentTimeEl) currentTimeEl.textContent = fmt(deck.currentTime);
      // Don't fight the user while they're dragging the scrubber.
      if (progressFill && deck.duration && !scrubbing) {
        progressFill.style.width = `${(deck.currentTime / deck.duration) * 100}%`;
        progressTrack?.setAttribute("aria-valuenow", String(Math.round((deck.currentTime / deck.duration) * 100)));
      }
      // Kick off the crossfade once we're within the crossfade window of the end.
      if (
        deck.duration &&
        !crossfading &&
        deck.duration - deck.currentTime <= CROSSFADE_SECONDS
      ) {
        startCrossfade();
      }
    });
    // Safety net: if a track ends without a crossfade having started
    // (e.g. track shorter than the crossfade window), advance immediately.
    deck.addEventListener("ended", () => {
      if (deck !== audio() || crossfading) return;
      load((current + 1) % items.length, true);
    });
  });

  // ===== Progress bar: scrub (drag), hover preview, keyboard =====
  const progressHover = document.getElementById("progress-hover");

  const ratioFromEvent = (clientX: number) => {
    if (!progressTrack) return 0;
    const rect = progressTrack.getBoundingClientRect();
    return Math.min(1, Math.max(0, (clientX - rect.left) / rect.width));
  };

  const renderProgress = (ratio: number) => {
    if (progressFill) progressFill.style.width = `${ratio * 100}%`;
    progressTrack?.setAttribute("aria-valuenow", String(Math.round(ratio * 100)));
  };

  const seekToRatio = (ratio: number) => {
    const deck = audio();
    if (!deck.duration) return;
    deck.currentTime = ratio * deck.duration;
    renderProgress(ratio);
    if (currentTimeEl) currentTimeEl.textContent = fmt(deck.currentTime);
    // Remaining time changed → re-arm the scheduled fade.
    if (!crossfading) scheduleFade();
  };

  // Hover preview: show where a click would land.
  progressTrack?.addEventListener("pointermove", (e) => {
    if (!progressHover) return;
    const ratio = ratioFromEvent(e.clientX);
    progressHover.style.width = `${ratio * 100}%`;
  });

  // Drag to scrub.
  progressTrack?.addEventListener("pointerdown", (e) => {
    if (!audio().duration) return;
    scrubbing = true;
    progressTrack.classList.add("is-scrubbing");
    progressTrack.setPointerCapture(e.pointerId);
    seekToRatio(ratioFromEvent(e.clientX));
  });
  progressTrack?.addEventListener("pointermove", (e) => {
    if (!scrubbing) return;
    seekToRatio(ratioFromEvent(e.clientX));
  });
  const endScrub = (e: PointerEvent) => {
    if (!scrubbing) return;
    scrubbing = false;
    progressTrack?.classList.remove("is-scrubbing");
    try {
      progressTrack?.releasePointerCapture(e.pointerId);
    } catch {}
  };
  progressTrack?.addEventListener("pointerup", endScrub);
  progressTrack?.addEventListener("pointercancel", endScrub);

  // Keyboard seeking (arrow keys = ±5s, Home/End = start/end).
  progressTrack?.addEventListener("keydown", (e) => {
    const deck = audio();
    if (!deck.duration) return;
    let handled = true;
    switch (e.key) {
      case "ArrowRight":
        deck.currentTime = Math.min(deck.duration, deck.currentTime + 5);
        break;
      case "ArrowLeft":
        deck.currentTime = Math.max(0, deck.currentTime - 5);
        break;
      case "Home":
        deck.currentTime = 0;
        break;
      case "End":
        deck.currentTime = deck.duration;
        break;
      default:
        handled = false;
    }
    if (handled) {
      e.preventDefault();
      renderProgress(deck.currentTime / deck.duration);
      if (!crossfading) scheduleFade();
    }
  });

  volumeTrack?.addEventListener("click", (e) => {
    const rect = volumeTrack.getBoundingClientRect();
    const ratio = Math.min(1, Math.max(0, (e.clientX - rect.left) / rect.width));
    masterVolume = ratio;
    // Apply immediately unless a crossfade is mid-ramp (it owns volume then).
    if (!crossfading) audio().volume = masterVolume;
    if (volumeFill) volumeFill.style.width = `${ratio * 100}%`;
  });

  // When the tab regains focus, timers may have been clamped/drifted while
  // hidden. Re-sync the progress UI and re-arm the fade schedule against the
  // real currentTime so nothing is left stale by background throttling.
  document.addEventListener("visibilitychange", () => {
    if (document.hidden) return;
    const deck = audio();
    if (deck.duration && !scrubbing) {
      renderProgress(deck.currentTime / deck.duration);
      if (currentTimeEl) currentTimeEl.textContent = fmt(deck.currentTime);
    }
    if (!crossfading && !deck.paused) scheduleFade();
  });

  // Preload the first track's metadata
  load(0);
</script>
