---
import Layout from "../layouts/Layout.astro";

// =====================================================================
//  TRACKS  ->  ADD YOUR 5 AUDIO FILES HERE
// ---------------------------------------------------------------------
//  1. Drop the audio files into:  public/audio/
//  2. Reference them below in `src` as "/audio/<filename>".
//     (Anything in public/ is served from the site root, so a file at
//      public/audio/little-peek.mp3 is reachable at "/audio/little-peek.mp3")
// =====================================================================
const tracks = [
  { title: "Little Peek", duration: "02:52", src: "/audio/little-peek.mp3" },
  { title: "At the Gates of Rimal Kubra", duration: "03:05", src: "/audio/at-the-gates-of-rimal-kubra.mp3" },
  { title: "The Ascension of Rimal Kubra", duration: "01:26", src: "/audio/the-ascension-of-rimal-kubra.mp3" },
  { title: "Ethereal Echo", duration: "02:56", src: "/audio/ethereal-echo.mp3" },
  { title: "Giants from the East and Elders", duration: "03:21", src: "/audio/giants-from-the-east-and-elders.mp3" },
];
---

<Layout title="GlenGlen">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 z-0 pointer-events-none">
    <img
      alt="Background"
      class="w-full h-full object-cover"
      src="https://lh3.googleusercontent.com/aida-public/AB6AXuAQplVDHVOF93Trnr6oHxZzmXHdG62q3XLdmf6sBW5hOVPmvUwybHtJxFzdgBtPl9h_JWwYj4SOnVv-BspY83J4WGt1qjU7VqYYUSz6EnN_-oyTgT0Fie3tmobyBKalW9qfr59MDoHfMpvvawZ4KFa1rUkiWJMTi2K3MHTBPD3J2gkFmyzrsGathUNXMUt3pz5oQwqO8CbsP3WrLP29nMeOZaVkzNpOQQmqLL1ERfkhIWKGS0JCR5ljCgGrmC5TRBG5dY0xoUfBt6Bg"
    />
    <div class="absolute inset-0 bg-background/60 backdrop-blur-[2px]"></div>
  </div>

  <!-- Main Content Canvas -->
  <main
    class="relative z-10 flex-grow flex flex-col items-center justify-center px-margin-mobile md:px-margin-desktop w-full h-full"
  >
    <!-- Band Identity -->
    <div class="text-center mb-12 transform hover:scale-105 transition-transform duration-700 ease-out">
      <h1
        class="font-display-lg text-[10vw] leading-none text-primary drop-shadow-[0_0_20px_rgba(86,251,160,0.3)] tracking-tighter mix-blend-screen"
      >
        GlenGlen
      </h1>
      <div class="mt-4 inline-block glass-panel rounded-full px-6 py-2 bg-surface/30">
        <span class="font-label-sm text-label-sm text-secondary tracking-widest uppercase">Psychedelic Rock</span>
      </div>
    </div>

    <!-- Music Player Container -->
    <div class="w-full max-w-2xl glass-panel bg-surface/20 rounded-xl overflow-hidden flex flex-col backdrop-blur-xl">
      <!-- Tracklist -->
      <div class="p-unit md:p-gutter">
        <ul class="flex flex-col gap-2" id="tracklist">
          {
            tracks.map((track, i) => (
              <li
                class:list={[
                  "track-item flex items-center justify-between p-3 rounded-lg transition-colors cursor-pointer group",
                  i === 0 ? "bg-white/5 hover:bg-white/10" : "hover:bg-white/5",
                ]}
                data-index={i}
                data-src={track.src}
                data-title={track.title}
              >
                <div class="flex items-center gap-4">
                  <span
                    class:list={[
                      "track-indicator relative flex items-center justify-center w-6 h-6 transition-colors group-hover:text-primary",
                      i === 0 ? "text-primary/50" : "text-on-surface-variant/50",
                    ]}
                  >
                    {/* Play icon: shown by default; hidden while this track is playing */}
                    <span class="track-icon-play material-symbols-outlined absolute inset-0 flex items-center justify-center">
                      play_arrow
                    </span>
                    {/* Pause icon: shown on hover while this track is playing */}
                    <span class="track-icon-pause material-symbols-outlined absolute inset-0 hidden items-center justify-center text-primary">
                      pause
                    </span>
                    {/* Animated equalizer: shown while this track is playing (and not hovered) */}
                    <span class="track-eq hidden gap-[2px] items-end h-3 text-primary" aria-hidden="true">
                      <span class="eq-bar"></span>
                      <span class="eq-bar"></span>
                      <span class="eq-bar"></span>
                    </span>
                  </span>
                  <div>
                    <h3
                      class:list={[
                        "track-title font-body-md text-[17px] leading-snug tracking-[-0.01em] transition-colors group-hover:text-on-surface",
                        i === 0 ? "text-on-surface font-semibold" : "text-on-surface/80 font-medium",
                      ]}
                    >
                      {track.title}
                    </h3>
                    <p
                      class:list={[
                        "font-label-sm text-[11px] tracking-wider mt-0.5 tabular-nums",
                        i === 0 ? "text-on-surface-variant" : "text-on-surface-variant/70",
                      ]}
                    >
                      {track.duration}
                    </p>
                  </div>
                </div>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Current Track Controls (Integrated into container) -->
      <div class="bg-surface-container-high/40 p-gutter border-t border-tertiary/10 flex flex-col gap-4">
        <!-- Progress Bar -->
        <div class="w-full flex items-center gap-3">
          <span class="font-label-sm text-label-sm text-on-surface-variant tabular-nums w-10 text-right" id="current-time">
            00:00
          </span>
          <div
            class="progress-bar group/progress flex-grow relative flex items-center h-4 cursor-pointer select-none touch-none"
            id="progress-track"
            role="slider"
            tabindex="0"
            aria-label="Seek"
            aria-valuemin="0"
            aria-valuemax="100"
            aria-valuenow="0"
          >
            <!-- Rail -->
            <div class="progress-rail relative w-full h-1 bg-surface-variant rounded-full overflow-visible transition-[height] duration-150 ease-out">
              <!-- Hover preview (where you'd seek to) -->
              <div
                class="absolute top-0 left-0 h-full w-0 bg-on-surface/10 rounded-full opacity-0 group-hover/progress:opacity-100 transition-opacity pointer-events-none"
                id="progress-hover"
              >
              </div>
              <!-- Played portion -->
              <div
                class="absolute top-0 left-0 h-full w-0 bg-secondary rounded-full shadow-[0_0_10px_rgba(149,204,255,0.8)]"
                id="progress-fill"
              >
                <!-- Draggable thumb -->
                <span
                  class="progress-thumb absolute right-0 top-1/2 -translate-y-1/2 translate-x-1/2 w-3 h-3 rounded-full bg-secondary shadow-[0_0_8px_rgba(149,204,255,0.9)] scale-0 group-hover/progress:scale-100 transition-transform duration-150 ease-out"
                  id="progress-thumb"
                >
                </span>
              </div>
            </div>
          </div>
          <span class="font-label-sm text-label-sm text-on-surface-variant tabular-nums w-10" id="total-time">00:00</span>
        </div>

        <!-- Controls -->
        <div class="grid grid-cols-[1fr_auto_1fr] items-center gap-3">
          <div class="flex items-center gap-3 min-w-0">
            <div class="w-12 h-12 rounded-md bg-surface-variant/50 flex items-center justify-center overflow-hidden relative shrink-0">
              <div class="absolute inset-0 bg-gradient-to-br from-primary/20 to-secondary/20"></div>
              <span class="material-symbols-outlined text-primary/80 absolute">graphic_eq</span>
            </div>
            <div class="hidden sm:block min-w-0">
              <h4 class="font-body-md text-on-surface font-semibold leading-tight truncate" id="now-playing-title">
                {tracks[0].title}
              </h4>
              <p class="font-label-sm text-on-surface-variant/70">GlenGlen</p>
            </div>
          </div>
          <div class="flex items-center gap-6 justify-self-center">
            <button class="text-on-surface-variant hover:text-secondary transition-colors" id="prev-btn">
              <span class="material-symbols-outlined">skip_previous</span>
            </button>
            <button
              class="w-12 h-12 rounded-full bg-primary text-on-primary flex items-center justify-center neon-glow hover:scale-105 active:scale-95 transition-all"
              id="play-btn"
            >
              <span class="material-symbols-outlined" id="play-icon" style="font-variation-settings: 'FILL' 1;">
                play_arrow
              </span>
            </button>
            <button class="text-on-surface-variant hover:text-secondary transition-colors" id="next-btn">
              <span class="material-symbols-outlined">skip_next</span>
            </button>
          </div>
          <div class="hidden sm:flex items-center gap-2 justify-self-end">
            <span class="material-symbols-outlined text-on-surface-variant text-sm">volume_up</span>
            <div class="w-16 h-1 bg-surface-variant rounded-full overflow-hidden cursor-pointer" id="volume-track">
              <div class="h-full w-2/3 bg-primary/70 rounded-full" id="volume-fill"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

</Layout>

<script>
  const items = Array.from(document.querySelectorAll<HTMLLIElement>(".track-item"));
  const playBtn = document.getElementById("play-btn");
  const playIcon = document.getElementById("play-icon");
  const prevBtn = document.getElementById("prev-btn");
  const nextBtn = document.getElementById("next-btn");
  const progressTrack = document.getElementById("progress-track");
  const progressFill = document.getElementById("progress-fill");
  const currentTimeEl = document.getElementById("current-time");
  const totalTimeEl = document.getElementById("total-time");
  const nowPlayingTitle = document.getElementById("now-playing-title");
  const volumeTrack = document.getElementById("volume-track");
  const volumeFill = document.getElementById("volume-fill");

  // ===== Crossfade configuration =====
  // Length of the overlap between a track ending and the next starting.
  // No silent gap occurs: the next track begins while the current is still
  // fading out. Tweak this value (in seconds) to taste.
  const CROSSFADE_SECONDS = 0.6;

  // Two "decks" let us overlap two tracks for a true gapless crossfade.
  // A single <audio> element can't overlap with itself.
  const decks = [new Audio(), new Audio()];
  decks.forEach((d) => {
    d.preload = "auto";
  });
  let activeDeck = 0; // index into `decks` that is the foreground track
  let masterVolume = decks[0].volume; // user-set volume (0..1), independent of fade
  let crossfading = false;
  let scrubbing = false; // true while the user is dragging the progress bar

  const audio = () => decks[activeDeck];
  const other = () => decks[activeDeck === 0 ? 1 : 0];

  let current = 0;

  const fmt = (s: number) => {
    if (!isFinite(s)) return "00:00";
    const m = Math.floor(s / 60);
    const sec = Math.floor(s % 60);
    return `${String(m).padStart(2, "0")}:${String(sec).padStart(2, "0")}`;
  };

  function highlight(index: number) {
    items.forEach((item, i) => {
      const icon = item.querySelector(".track-icon");
      const title = item.querySelector(".track-title");
      if (i === index) {
        item.classList.add("bg-white/5");
        icon?.classList.add("text-primary/50");
        icon?.classList.remove("text-on-surface-variant/50");
        title?.classList.add("text-on-surface", "font-semibold");
        title?.classList.remove("text-on-surface/80", "font-medium");
      } else {
        item.classList.remove("bg-white/5");
        icon?.classList.remove("text-primary/50");
        icon?.classList.add("text-on-surface-variant/50");
        title?.classList.remove("text-on-surface", "font-semibold");
        title?.classList.add("text-on-surface/80", "font-medium");
      }
    });
  }

  function setPlayingState(playing: boolean) {
    items.forEach((item, i) => {
      item.classList.toggle("is-playing", playing && i === current);
    });
  }

  function updateNowPlaying(index: number) {
    const item = items[index];
    if (!item) return;
    if (nowPlayingTitle) nowPlayingTitle.textContent = item.dataset.title ?? "";
    highlight(index);
  }

  // Load a track onto the active deck and (optionally) play it.
  // Used for explicit selection / prev / next, NOT for the auto crossfade.
  function load(index: number, autoplay = false) {
    const item = items[index];
    if (!item) return;
    cancelCrossfade();
    current = index;
    const deck = audio();
    deck.volume = masterVolume;
    deck.src = item.dataset.src ?? "";
    updateNowPlaying(index);
    setPlayingState(false);
    if (autoplay) deck.play().catch(() => {});
  }

  function togglePlay() {
    const deck = audio();
    if (!deck.src) {
      load(current, true);
      return;
    }
    if (deck.paused) deck.play().catch(() => {});
    else deck.pause();
  }

  // ===== Crossfade engine =====
  let crossfadeRAF = 0;

  function cancelCrossfade() {
    if (crossfadeRAF) cancelAnimationFrame(crossfadeRAF);
    crossfadeRAF = 0;
    crossfading = false;
    // Make sure the background deck is stopped and silenced.
    const bg = other();
    bg.pause();
    bg.currentTime = 0;
    bg.volume = masterVolume;
  }

  // Begin overlapping the next track on the other deck and ramp volumes.
  function startCrossfade() {
    if (crossfading) return;
    const nextIndex = (current + 1) % items.length;
    const item = items[nextIndex];
    if (!item) return;

    crossfading = true;
    const fromDeck = audio();
    const toDeck = other();

    toDeck.src = item.dataset.src ?? "";
    toDeck.currentTime = 0;
    toDeck.volume = 0;

    // Once the incoming track can play, the foreground switches to it so the
    // UI (progress, title, indicator) tracks the track you actually hear.
    current = nextIndex;
    activeDeck = activeDeck === 0 ? 1 : 0; // toDeck becomes active
    updateNowPlaying(current);
    setPlayingState(true);

    toDeck.play().catch(() => {});

    const start = performance.now();
    const durationMs = CROSSFADE_SECONDS * 1000;

    const step = (now: number) => {
      const t = Math.min(1, (now - start) / durationMs);
      // Equal-power crossfade keeps perceived loudness constant (no dip).
      const inGain = Math.sin((t * Math.PI) / 2);
      const outGain = Math.cos((t * Math.PI) / 2);
      toDeck.volume = masterVolume * inGain;
      fromDeck.volume = masterVolume * outGain;

      if (t < 1) {
        crossfadeRAF = requestAnimationFrame(step);
      } else {
        fromDeck.pause();
        fromDeck.currentTime = 0;
        fromDeck.volume = masterVolume;
        toDeck.volume = masterVolume;
        crossfading = false;
        crossfadeRAF = 0;
      }
    };
    crossfadeRAF = requestAnimationFrame(step);
  }

  playBtn?.addEventListener("click", togglePlay);
  prevBtn?.addEventListener("click", () => load((current - 1 + items.length) % items.length, !audio().paused));
  nextBtn?.addEventListener("click", () => load((current + 1) % items.length, !audio().paused));

  items.forEach((item, i) => {
    item.addEventListener("click", () => {
      // Clicking the track that's already loaded toggles play/pause
      // instead of restarting it; clicking a different track loads + plays it.
      if (i === current && audio().src && !crossfading) {
        togglePlay();
      } else {
        load(i, true);
      }
    });
  });

  // Wire shared playback events for BOTH decks; handlers act only when the
  // event comes from whichever deck is currently active.
  decks.forEach((deck) => {
    deck.addEventListener("play", () => {
      if (deck !== audio()) return;
      if (playIcon) playIcon.textContent = "pause";
      setPlayingState(true);
    });
    deck.addEventListener("pause", () => {
      if (deck !== audio() || crossfading) return;
      if (playIcon) playIcon.textContent = "play_arrow";
      setPlayingState(false);
    });
    deck.addEventListener("loadedmetadata", () => {
      if (deck !== audio()) return;
      if (totalTimeEl) totalTimeEl.textContent = fmt(deck.duration);
    });
    deck.addEventListener("timeupdate", () => {
      if (deck !== audio()) return;
      if (currentTimeEl) currentTimeEl.textContent = fmt(deck.currentTime);
      // Don't fight the user while they're dragging the scrubber.
      if (progressFill && deck.duration && !scrubbing) {
        progressFill.style.width = `${(deck.currentTime / deck.duration) * 100}%`;
        progressTrack?.setAttribute("aria-valuenow", String(Math.round((deck.currentTime / deck.duration) * 100)));
      }
      // Kick off the crossfade once we're within the crossfade window of the end.
      if (
        deck.duration &&
        !crossfading &&
        deck.duration - deck.currentTime <= CROSSFADE_SECONDS
      ) {
        startCrossfade();
      }
    });
    // Safety net: if a track ends without a crossfade having started
    // (e.g. track shorter than the crossfade window), advance immediately.
    deck.addEventListener("ended", () => {
      if (deck !== audio() || crossfading) return;
      load((current + 1) % items.length, true);
    });
  });

  // ===== Progress bar: scrub (drag), hover preview, keyboard =====
  const progressHover = document.getElementById("progress-hover");

  const ratioFromEvent = (clientX: number) => {
    if (!progressTrack) return 0;
    const rect = progressTrack.getBoundingClientRect();
    return Math.min(1, Math.max(0, (clientX - rect.left) / rect.width));
  };

  const renderProgress = (ratio: number) => {
    if (progressFill) progressFill.style.width = `${ratio * 100}%`;
    progressTrack?.setAttribute("aria-valuenow", String(Math.round(ratio * 100)));
  };

  const seekToRatio = (ratio: number) => {
    const deck = audio();
    if (!deck.duration) return;
    deck.currentTime = ratio * deck.duration;
    renderProgress(ratio);
    if (currentTimeEl) currentTimeEl.textContent = fmt(deck.currentTime);
  };

  // Hover preview: show where a click would land.
  progressTrack?.addEventListener("pointermove", (e) => {
    if (!progressHover) return;
    const ratio = ratioFromEvent(e.clientX);
    progressHover.style.width = `${ratio * 100}%`;
  });

  // Drag to scrub.
  progressTrack?.addEventListener("pointerdown", (e) => {
    if (!audio().duration) return;
    scrubbing = true;
    progressTrack.classList.add("is-scrubbing");
    progressTrack.setPointerCapture(e.pointerId);
    seekToRatio(ratioFromEvent(e.clientX));
  });
  progressTrack?.addEventListener("pointermove", (e) => {
    if (!scrubbing) return;
    seekToRatio(ratioFromEvent(e.clientX));
  });
  const endScrub = (e: PointerEvent) => {
    if (!scrubbing) return;
    scrubbing = false;
    progressTrack?.classList.remove("is-scrubbing");
    try {
      progressTrack?.releasePointerCapture(e.pointerId);
    } catch {}
  };
  progressTrack?.addEventListener("pointerup", endScrub);
  progressTrack?.addEventListener("pointercancel", endScrub);

  // Keyboard seeking (arrow keys = ±5s, Home/End = start/end).
  progressTrack?.addEventListener("keydown", (e) => {
    const deck = audio();
    if (!deck.duration) return;
    let handled = true;
    switch (e.key) {
      case "ArrowRight":
        deck.currentTime = Math.min(deck.duration, deck.currentTime + 5);
        break;
      case "ArrowLeft":
        deck.currentTime = Math.max(0, deck.currentTime - 5);
        break;
      case "Home":
        deck.currentTime = 0;
        break;
      case "End":
        deck.currentTime = deck.duration;
        break;
      default:
        handled = false;
    }
    if (handled) {
      e.preventDefault();
      renderProgress(deck.currentTime / deck.duration);
    }
  });

  volumeTrack?.addEventListener("click", (e) => {
    const rect = volumeTrack.getBoundingClientRect();
    const ratio = Math.min(1, Math.max(0, (e.clientX - rect.left) / rect.width));
    masterVolume = ratio;
    // Apply immediately unless a crossfade is mid-ramp (it owns volume then).
    if (!crossfading) audio().volume = masterVolume;
    if (volumeFill) volumeFill.style.width = `${ratio * 100}%`;
  });

  // Preload the first track's metadata
  load(0);
</script>
